{
    "version": "0.0.1",
    "id": "heat_2",
    "title": {"en": "HELCOM Annual Indicator"},
    "description": {
        "en": "Process to compute the HELCOM Annual Indicator for the HEAT assessment tool. This process represents subpart 2 of the original HEAT assessment computation script. For more info, please go to: https://github.com/ices-tools-prod/HEAT/tree/master"
    },
    "jobControlOptions": ["sync-execute", "async-execute"],
    "keywords": ["HELCOM", "HEAT"],
    "links": [{
        "type": "text/html",
        "rel": "about",
        "title": "GitHub repo for the original HEAT analysis",
        "href": "https://github.com/ices-tools-prod/HEAT/tree/master",
        "hreflang": "en-US"
    }],
    "inputs": {
        "assessment_period": {
            "title": "Assessment Period",
            "description": "Ask HELCOM. Example: 2011-2016",
            "schema": {
                "type": "string",
                "enum": [
                  "2011-2016",
                  "2016-2021",
                  "1877-9999"
                ]
            },
            "minOccurs": 1,
            "maxOccurs": 1,
            "metadata": null,
            "keywords": []
        },
        "bottle_data": {
            "title": "Input bottle data TODO",
            "description": "Input bottle data, TODO, possibly downloaded from ICES. Optional. Default is provided.",
            "schema": { "type": "string"},
            "minOccurs": 0,
            "maxOccurs": 1,
            "metadata": null,
            "keywords": []
        },
        "ctd_data": {
            "title": "Input CTD data TODO",
            "description": "Input ctd data. Optional. Default is provided.",
            "schema": { "type": "string"},
            "minOccurs": 0,
            "maxOccurs": 1,
            "metadata": null,
            "keywords": []
        },
        "pump_Data": {
            "title": "Input pump data TODO",
            "description": "Input pump data, TODO. Optional. Default is provided.",
            "schema": { "type": "string"},
            "minOccurs": 0,
            "maxOccurs": 1,
            "metadata": null,
            "keywords": []
        }
    },
    "outputs": {
        "station_samples": {
            "title": "StationSamples.csv",
            "description": "Combined StationSamples.csv. Relevant samples only, whatever that means.",
            "schema": {
                "type": "object",
                "contentMediaType": "application/csv"
            }
        },
        "bottle_samples": {
            "title": "StationSamplesBOT.csv",
            "description": "Bottle samples used for this.",
            "schema": {
                "type": "object",
                "contentMediaType": "application/csv"
            }
        },
        "pump_samples": {
            "title": "StationSamplesPMP.csv",
            "description": "Pump samples used for this.",
            "schema": {
                "type": "object",
                "contentMediaType": "application/csv"
            }
        },
        "ctd_samples": {
            "title": "StationSamplesCTD.csv",
            "description": "CTD samples used for this.",
            "schema": {
                "type": "object",
                "contentMediaType": "application/csv"
            }
        },
        "units_gridded": {
            "title": "units_gridded.shp",
            "description": "Gridded spatial units, as shapefile, used for this process.",
            "schema": {
                "type": "object",
                "contentMediaType": "application/shp"
            }
        }
    },
    "example": {
        "inputs": {
            "assessmentPeriod": "2011-2016",
            "combined_Chlorophylla_IsWeighted": "true"
        }
    }
}